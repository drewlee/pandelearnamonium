{
  "name": "pandelearnamonium",
  "version": "1.0.0",
  "description": "It's a pandelearnamonium!",
  "private": true,
  "author": "Andrew A. Lee <andrew@andrewleedev.com>",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/drewlee/pandelearnamonium.git"
  },
  "workspaces": [
    "./packages/*"
  ],
  "scripts": {
    "build:ts": "npm run build:ts --workspaces",
    "eslint": "npm run eslint --workspaces",
    "fcc": "npm run fcc --workspaces --if-present",
    "fcc:clean": "npm run fcc:clean --workspaces --if-present",
    "lint": "npm run lint --workspaces",
    "lint:check": "npm run lint:check --workspaces",
    "prepare": "husky",
    "prettier": "npm run prettier --workspaces",
    "prettier:check": "npm run prettier:check --workspaces",
    "prettier:write": "npm run prettier:write --workspaces",
    "stylelint": "npm run stylelint --workspaces --if-present",
    "test": "npm run test --workspaces",
    "ts-node": "npm run ts-node --workspaces --if-present",
    "vite:build": "npm run vite:build --workspaces --if-present",
    "vite:preview": "npm run vite:preview --workspaces --if-present",
    "vite:serve": "npm run vite:serve --workspaces --if-present",
    "vitest": "npm run vitest --workspaces"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-tsdoc": "^0.5.2",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "3.9.5",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  },
  "volta": {
    "node": "24.13.0",
    "npm": "11.18.0"
  },
  "allowScripts": {
    "fsevents@2.3.3": true
  }
}
